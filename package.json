{
  "name": "statxt-android",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "set EXPO_USE_COMMUNITY_AUTOLINKING=1&& expo run android",
    "android:emulator": "set REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1&& set EXPO_USE_COMMUNITY_AUTOLINKING=1&& expo run android",
    "prebuild": "expo prebuild --platform android",
    "prebuild:clean": "expo prebuild --platform android --clean",
    "build:apk": "cd android && gradlew.bat assembleRelease",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.1",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.8",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.18",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "math-intrinsics": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.19.13",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@react-native-community/cli": "^15.0.0",
    "@types/react": "18.3.12",
    "babel-preset-expo": "~12.0.0",
    "typescript": "~5.7.2"
  }
}